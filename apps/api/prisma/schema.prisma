// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums — Order / Payment
// ─────────────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING_PAYMENT
  PENDING_APPROVAL
  PAID
  FAILED
}

enum PaymentMethod {
  STRIPE
  MERCADOPAGO
  TRANSFER
}

enum TransferStatus {
  WAITING_CREDS
  QUEUED
  IN_PROGRESS
  COMPLETED
  ERROR
}

enum Platform {
  PS
  XB
  PC
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums — Loyalty & Roles (Fase 3)
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum UserTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String?
  password_hash String?

  // Loyalty & permissions (Fase 3)
  role            UserRole @default(USER)
  tier            UserTier @default(BRONZE)
  wallet_balance  Decimal  @default(0.00) @db.Decimal(10, 2)
  xp_points       Int      @default(0)

  created_at DateTime @default(now())
  orders     Order[]

  @@map("users")
}

model Order {
  id                   String         @id @default(uuid())
  user_id              String
  user                 User           @relation(fields: [user_id], references: [id])
  amount_coins         Int
  price_paid           Decimal        @db.Decimal(10, 2)
  status               OrderStatus    @default(PENDING_PAYMENT)
  paymentMethod        PaymentMethod
  platform             Platform       @default(PS)
  transfer_status      TransferStatus @default(WAITING_CREDS)
  fut_transfer_id      String?
  coins_transferred    Int            @default(0)
  fut_account_check    String?
  fut_economy_state    String?
  ea_email             String?
  ea_password          String?
  ea_backup_codes      String?
  ea_account_encrypted String?
  proof_image_url      String?

  // Loyalty — cashback y uso de wallet (Fase 3)
  cashback_earned Decimal @default(0.00) @db.Decimal(10, 2)
  wallet_used     Decimal @default(0.00) @db.Decimal(10, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("orders")
}
