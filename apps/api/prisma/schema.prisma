// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING_PAYMENT
  PENDING_APPROVAL
  PAID
  FAILED
}

enum PaymentMethod {
  STRIPE
  MERCADOPAGO
  TRANSFER
}

enum TransferStatus {
  WAITING_CREDS
  QUEUED
  IN_PROGRESS
  COMPLETED
  ERROR
}

enum Platform {
  PS
  XB
  PC
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String?
  password_hash String?
  created_at    DateTime @default(now())
  orders        Order[]

  @@map("users")
}

model Order {
  id                   String         @id @default(uuid())
  user_id              String
  user                 User           @relation(fields: [user_id], references: [id])
  amount_coins         Int
  price_paid           Decimal        @db.Decimal(10, 2)
  status               OrderStatus    @default(PENDING_PAYMENT)
  paymentMethod        PaymentMethod
  platform             Platform       @default(PS)
  transfer_status      TransferStatus @default(WAITING_CREDS)
  fut_transfer_id      String?
  coins_transferred    Int            @default(0)
  fut_account_check    String?
  fut_economy_state    String?
  ea_email             String?
  ea_password          String?
  ea_backup_codes      String?
  ea_account_encrypted String?
  proof_image_url      String?
  created_at           DateTime       @default(now())
  updated_at           DateTime       @updatedAt

  @@map("orders")
}
